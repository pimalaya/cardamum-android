<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Neutral surfaces; the night variant lives in values-night/. Every
         other colour is pulled from the device theme (?android:attr/...). -->
    <color name="divider">#BDBDBD</color>
    <color name="surface">#EEEEEE</color>

    <!-- The sync loader's veil: surface at 75% opacity, so the screen
         underneath stays visible while the overlay swallows touches. -->
    <color name="scrim">#BFEEEEEE</color>

</resources>
