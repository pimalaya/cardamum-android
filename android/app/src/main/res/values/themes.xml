<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- DeviceDefault so the app inherits the phone maker's theme
         (colorPrimary, colorAccent, text colours), not a fixed Google
         palette. The night variant in values-night/ switches to the dark
         base, so the app follows the system light/dark setting; every
         colour in the UI comes from these attributes. -->
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar" />

</resources>
