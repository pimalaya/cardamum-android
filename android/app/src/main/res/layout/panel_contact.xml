<?xml version="1.0" encoding="utf-8"?>
<!-- The contact editor's content: one settings-style page (accent
     section headers over tappable full-bleed items, each opening an
     edit dialog); its bar elements and save FAB live in the persistent
     chrome (activity_main.xml). The page's bottom padding keeps the
     last row clear of the FAB. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/contact_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contact_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp" />

    </ScrollView>

</FrameLayout>
