<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <ImageButton
            android:id="@+id/contact_back"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/contact_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- The addressbooks the contact belongs to (docs/merged-view.md). -->
        <ImageButton
            android:id="@+id/contact_books"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/manage_books_title"
            android:src="@drawable/ic_group_add"
            android:tint="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/contact_save"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/contact_save"
            android:src="@drawable/ic_person_check"
            android:tint="?android:attr/textColorPrimary" />

    </LinearLayout>

    <TabHost
        android:id="@+id/contact_tabs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface">

                <HorizontalScrollView
                    android:id="@+id/contact_tab_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <TabWidget
                        android:id="@android:id/tabs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </HorizontalScrollView>

                <!-- Hints that the tab strip scrolls further left/right. -->
                <ImageView
                    android:id="@+id/contact_tab_less"
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@color/surface"
                    android:contentDescription="@string/more"
                    android:scaleType="center"
                    android:src="@drawable/ic_chevron_left"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/contact_tab_more"
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:background="@color/surface"
                    android:contentDescription="@string/more"
                    android:scaleType="center"
                    android:src="@drawable/ic_chevron_right" />

            </FrameLayout>

            <FrameLayout
                android:id="@android:id/tabcontent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ScrollView
                    android:id="@+id/contact_tab_name"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contact_name_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />

                </ScrollView>

                <ScrollView
                    android:id="@+id/contact_tab_contact"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contact_contact_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />

                </ScrollView>

                <ScrollView
                    android:id="@+id/contact_tab_address"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contact_address_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />

                </ScrollView>

                <ScrollView
                    android:id="@+id/contact_tab_work"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contact_work_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />

                </ScrollView>

                <ScrollView
                    android:id="@+id/contact_tab_notes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contact_notes_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp" />

                </ScrollView>

                <ScrollView
                    android:id="@+id/contact_tab_source"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/contact_source"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textIsSelectable="true"
                        android:typeface="monospace" />

                </ScrollView>

            </FrameLayout>
        </LinearLayout>
    </TabHost>

</LinearLayout>
