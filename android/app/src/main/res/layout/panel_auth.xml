<?xml version="1.0" encoding="utf-8"?>
<!-- The auth flow, a whole-frame overlay sliding in over the
     addressbooks drawer from the left, its own bar included, over an
     inner flipper holding the steps (email, config, books): navigating
     the flow slides only the step content. The shared FAB is the
     step's continue action. The arrow steps back (leaving from the
     welcome step), the cross always leaves; both land on the drawer,
     empty or not. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_auth"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/auth_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="@dimen/app_bar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <ImageButton
            android:id="@+id/auth_back"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Retitled per step in applyAuthChrome. -->
        <TextView
            android:id="@+id/auth_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:paddingEnd="@dimen/app_bar_title_padding"
            android:text="@string/auth_step_email"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/auth_cancel"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/cancel_auth"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary" />

    </LinearLayout>

    <ViewFlipper
        android:id="@+id/auth_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/panel_email" />

        <include layout="@layout/panel_config" />

        <include layout="@layout/panel_books" />

    </ViewFlipper>

</LinearLayout>
