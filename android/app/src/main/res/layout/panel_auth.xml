<?xml version="1.0" encoding="utf-8"?>
<!-- The auth flow shell: one persistent app bar over an inner flipper
     holding the steps (email, config, books), so navigating the flow
     only slides the step content. The bar hides on the first-run
     welcome (chrome-free, no way back) and its cross only shows when
     adding a further account. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/auth_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <ImageButton
            android:id="@+id/auth_back"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:text="@string/new_account"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/auth_cancel"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel_auth"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

    </LinearLayout>

    <ViewFlipper
        android:id="@+id/auth_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/panel_email" />

        <include layout="@layout/panel_config" />

        <include layout="@layout/panel_books" />

    </ViewFlipper>

</LinearLayout>
