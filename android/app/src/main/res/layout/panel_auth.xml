<?xml version="1.0" encoding="utf-8"?>
<!-- The auth flow's content: an inner flipper holding the steps
     (email, config, books), so navigating the flow slides only the
     step content under the persistent app bar. With no account stored
     the flow has no way out: no cross, no back arrow on the welcome
     step (applyChrome in MainActivity). -->
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/auth_flipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/panel_email" />

    <include layout="@layout/panel_config" />

    <include layout="@layout/panel_books" />

</ViewFlipper>
