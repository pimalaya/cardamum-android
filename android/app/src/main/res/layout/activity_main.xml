<?xml version="1.0" encoding="utf-8"?>
<!-- One persistent app bar and one persistent FAB over the content
     flipper: navigating flips only the inner content, the chrome stays
     put. The bar carries the union of every screen's elements;
     applyChrome (MainActivity) turns the right set on per screen. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="@dimen/app_bar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <!-- Editor, addressbooks, advanced and auth screens. -->
        <ImageButton
            android:id="@+id/bar_back"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Contacts: opens the addressbooks management screen. -->
        <ImageButton
            android:id="@+id/contacts_menu"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/subscriptions_title"
            android:src="@drawable/ic_menu"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Contacts selection mode: cancel the selection. -->
        <ImageButton
            android:id="@+id/contacts_close"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/cancel_selection"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- The screen's title (or the selected count). -->
        <TextView
            android:id="@+id/bar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:paddingEnd="@dimen/app_bar_title_padding"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Contacts search mode: the pill replaces the title. Its
             negative end margin slides it under the clear cross that
             follows, so the cross reads as inside the field while
             staying a regular bar button. -->
        <FrameLayout
            android:id="@+id/contacts_search_pill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="-48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/search_background"
            android:visibility="gone">

            <EditText
                android:id="@+id/contacts_search_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="@string/contacts_search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="24dp"
                android:paddingEnd="48dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:textSize="16sp" />

        </FrameLayout>

        <!-- Contacts search mode: clears the query and restores the
             title; the pill extends underneath it. -->
        <ImageButton
            android:id="@+id/contacts_search_close"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/clear"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Pushes the action icons to the right edge. -->
        <View
            android:id="@+id/contacts_bar_spacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Contacts: opens the in-bar search field. -->
        <ImageButton
            android:id="@+id/contacts_search"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/contacts_search"
            android:src="@drawable/ic_search"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Contacts selection mode: merge the selected cards. -->
        <ImageButton
            android:id="@+id/contacts_merge"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/merge_selected"
            android:src="@drawable/ic_merge"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/contacts_delete"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/delete_selected"
            android:src="@drawable/ic_delete_bar"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Contacts: the sync icon gives way to a spinner while a
             sync runs. -->
        <FrameLayout
            android:id="@+id/contacts_sync_slot"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button">

            <ImageButton
                android:id="@+id/contacts_sync"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/contacts_sync"
                android:src="@drawable/ic_sync"
                android:tint="?android:attr/textColorPrimary" />

            <ProgressBar
                android:id="@+id/contacts_sync_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="?android:attr/textColorPrimary"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Editor: the advanced raw-property editor. -->
        <ImageButton
            android:id="@+id/contact_advanced"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/advanced_open"
            android:src="@drawable/ic_advanced"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Editor: the addressbooks the contact belongs to, the one
             placement gesture (docs/merged-view.md). -->
        <ImageButton
            android:id="@+id/contact_books"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/manage_books_title"
            android:src="@drawable/ic_link"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Auth: leaves the flow (only when an account exists). -->
        <ImageButton
            android:id="@+id/auth_cancel"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/cancel_auth"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ViewFlipper
            android:id="@+id/flipper"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include layout="@layout/panel_auth" />

            <include layout="@layout/panel_contacts" />

            <include layout="@layout/panel_contact" />

            <include layout="@layout/panel_home" />

            <include layout="@layout/panel_advanced" />

        </ViewFlipper>

        <!-- The screens' primary action: add on the lists, save on the
             editor (icon and action set per screen in applyChrome). -->
        <ImageButton
            android:id="@+id/fab"
            android:layout_width="@dimen/fab"
            android:layout_height="@dimen/fab"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/fab_margin"
            android:background="@drawable/fab_background"
            android:contentDescription="@string/contacts_add"
            android:elevation="@dimen/fab_elevation"
            android:src="@drawable/ic_add" />

    </FrameLayout>

</LinearLayout>
