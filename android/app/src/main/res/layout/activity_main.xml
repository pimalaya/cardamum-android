<?xml version="1.0" encoding="utf-8"?>
<!-- The main column (one persistent app bar over the content flipper:
     navigating flips only the inner content) plus two whole-frame
     overlays sliding over it, bar included (the addressbooks drawer
     and the auth sheet), and the one FAB fixed above everything.
     applyChrome (MainActivity) reconfigures the chrome per screen. -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content: the persistent app bar over the content flipper,
         the auth sheet overlay and the FAB, all under the drawer. It does
         not clip, so the FAB's elevation shadow (which spills past the
         snug fab_frame) renders in full. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <LinearLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="@dimen/app_bar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <!-- Editor, addressbooks, advanced and auth screens. -->
        <ImageButton
            android:id="@+id/bar_back"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Contacts: opens the addressbooks management screen. -->
        <ImageButton
            android:id="@+id/contacts_menu"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/subscriptions_title"
            android:src="@drawable/ic_menu"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Contacts selection mode: cancel the selection. -->
        <ImageButton
            android:id="@+id/contacts_close"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/cancel_selection"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- The screen's title (or the selected count). -->
        <TextView
            android:id="@+id/bar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:paddingEnd="@dimen/app_bar_title_padding"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Contacts search mode: the pill replaces the title. Its
             negative end margin slides it under the clear cross that
             follows, so the cross reads as inside the field while
             staying a regular bar button. -->
        <FrameLayout
            android:id="@+id/contacts_search_pill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="-48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/search_background"
            android:visibility="gone">

            <EditText
                android:id="@+id/contacts_search_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="@string/contacts_search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="24dp"
                android:paddingEnd="48dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:textSize="15sp" />

        </FrameLayout>

        <!-- Contacts search mode: clears the query and restores the
             title; the pill extends underneath it. -->
        <ImageButton
            android:id="@+id/contacts_search_close"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/clear"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Pushes the action icons to the right edge. -->
        <View
            android:id="@+id/contacts_bar_spacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Contacts: opens the in-bar search field. -->
        <ImageButton
            android:id="@+id/contacts_search"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/contacts_search"
            android:src="@drawable/ic_search"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Contacts selection mode: merge the selected cards. -->
        <ImageButton
            android:id="@+id/contacts_merge"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/merge_selected"
            android:src="@drawable/ic_merge"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/contacts_delete"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/delete_selected"
            android:src="@drawable/ic_delete_bar"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Contacts selection mode: select or clear every contact. The
             box is centred in an app-bar-button-wide slot, exactly like
             the per-row checkboxes (contact_end_slot). -->
        <FrameLayout
            android:id="@+id/contacts_select_all_slot"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/contacts_select_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:buttonTint="?android:attr/textColorPrimary"
                android:contentDescription="@string/select_all" />

        </FrameLayout>

        <!-- Contacts: the overflow menu (Synchronize, Find duplicates);
             its icon gives way to a spinner while a sync runs. -->
        <FrameLayout
            android:id="@+id/contacts_more_slot"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button">

            <ImageButton
                android:id="@+id/contacts_more"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/contacts_more"
                android:src="@drawable/ic_more_vert"
                android:tint="?android:attr/textColorPrimary" />

            <ProgressBar
                android:id="@+id/contacts_more_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="?android:attr/textColorPrimary"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Editor: the addressbooks the contact belongs to, the one
             placement gesture (docs/merged-view.md). -->
        <ImageButton
            android:id="@+id/contact_books"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/manage_books_title"
            android:src="@drawable/ic_addressbooks"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Editor: the advanced raw-property editor. -->
        <ImageButton
            android:id="@+id/contact_advanced"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/advanced_open"
            android:src="@drawable/ic_advanced"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Editor: save the contact; the FAB is the add-field action. -->
        <ImageButton
            android:id="@+id/contact_save"
            android:layout_width="@dimen/app_bar_button"
            android:layout_height="@dimen/app_bar_button"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@string/contact_save"
            android:src="@drawable/ic_check"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

    </LinearLayout>

    <ViewFlipper
        android:id="@+id/flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/panel_contacts" />

        <include layout="@layout/panel_contact" />

        <include layout="@layout/panel_advanced" />

        <include layout="@layout/panel_source" />

    </ViewFlipper>

    </LinearLayout>

    <!-- The auth sheet: a whole-frame overlay with its own bar, rising
         over the content (the drawer is closed while it runs). -->
    <include layout="@layout/panel_auth" />

    <!-- The screens' primary action, fixed above everything: add on
         the lists, save on the editor, continue through the auth flow
         (icon and action per screen in applyChrome). While an auth step
         works the loader sits on the disc, its icon hidden. -->
    <FrameLayout
        android:id="@+id/fab_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageButton
            android:id="@+id/fab"
            android:layout_width="@dimen/fab"
            android:layout_height="@dimen/fab"
            android:background="@drawable/fab_background"
            android:contentDescription="@string/contacts_add"
            android:elevation="@dimen/fab_elevation"
            android:src="@drawable/ic_add" />

        <ProgressBar
            android:id="@+id/fab_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:elevation="@dimen/fab_elevation"
            android:indeterminateTint="?android:attr/colorPrimary"
            android:visibility="gone" />

    </FrameLayout>

    </FrameLayout>

    <!-- The addressbooks drawer: a title bar over the scrollable accounts
         (reloadHome fills home_container) and a fixed footer of actions.
         Width caps at 320dp per the drawer spec. -->
    <LinearLayout
        android:id="@+id/drawer_panel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?android:attr/colorBackground"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- Title bar: a manage-accounts icon then the title. The 48dp
             tall icon makes the bar as tall as the app bar so their
             bottoms line up. -->
        <LinearLayout
            android:id="@+id/drawer_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/colorPrimary"
            android:gravity="center_vertical"
            android:minHeight="@dimen/app_bar_height"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="@dimen/app_bar_padding">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                android:scaleType="center"
                android:src="@drawable/ic_account"
                android:tint="?android:attr/textColorPrimary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/subscriptions_title"
                android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
                android:textColor="?android:attr/textColorPrimary" />

            <ImageButton
                android:id="@+id/drawer_header_add"
                android:layout_width="@dimen/app_bar_button"
                android:layout_height="@dimen/app_bar_button"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/add_account"
                android:src="@drawable/ic_add"
                android:tint="?android:attr/textColorPrimary" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/home_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>

            <!-- The drawer's empty state, shown when no real account is
                 configured: an icon, a title, and an add-account button. -->
            <LinearLayout
                android:id="@+id/drawer_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:alpha="0.25"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_no_account"
                    android:tint="?android:attr/textColorSecondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.25"
                    android:gravity="center"
                    android:text="@string/no_account"
                    android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="18sp" />

                <!-- Pill button; its text and plus are tinted in code to
                     contrast the accent, like the FAB. -->
                <Button
                    android:id="@+id/drawer_empty_add"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_pill"
                    android:drawableStart="@drawable/ic_add"
                    android:drawablePadding="4dp"
                    android:minHeight="40dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="20dp"
                    android:stateListAnimator="@null"
                    android:text="@string/add_account" />

            </LinearLayout>

        </FrameLayout>

        <!-- Bottom band on the same primary colour: sync, then About (its
             dialog carries the app version). Add account lives in the
             title bar's plus. -->
        <LinearLayout
            android:id="@+id/drawer_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/colorPrimary"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/drawer_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="@dimen/item_height"
                android:orientation="horizontal"
                android:paddingStart="@dimen/item_padding"
                android:paddingEnd="@dimen/item_padding">

                <FrameLayout
                    android:layout_width="@dimen/item_icon"
                    android:layout_height="@dimen/item_icon"
                    android:layout_marginEnd="@dimen/item_gap">

                    <ImageView
                        android:id="@+id/drawer_sync_icon"
                        android:layout_width="@dimen/item_icon"
                        android:layout_height="@dimen/item_icon"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_sync"
                        android:tint="?android:attr/textColorPrimary" />

                    <ProgressBar
                        android:id="@+id/drawer_sync_progress"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="@dimen/item_icon"
                        android:layout_height="@dimen/item_icon"
                        android:layout_gravity="center"
                        android:indeterminateTint="?android:attr/textColorPrimary"
                        android:visibility="gone" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_accounts"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/item_text" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawer_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="@dimen/item_height"
                android:orientation="horizontal"
                android:paddingStart="@dimen/item_padding"
                android:paddingEnd="@dimen/item_padding">

                <ImageView
                    android:layout_width="@dimen/item_icon"
                    android:layout_height="@dimen/item_icon"
                    android:layout_marginEnd="@dimen/item_gap"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info"
                    android:tint="?android:attr/textColorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="@dimen/item_text" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
