<?xml version="1.0" encoding="utf-8"?>
<!-- M3 two-line list item. The 40dp start padding plus the avatar's
     16dp margin land the avatar's left edge at 56dp, aligned with the
     app bar title (4dp bar padding + 48dp button + 4dp title padding);
     the row stays full-bleed so its ripple spans the whole line. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="40dp"
    android:paddingTop="10dp"
    android:paddingEnd="@dimen/app_bar_padding"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/contact_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:lineHeight="24dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/contact_link_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_link_add"
                android:visibility="gone" />

            <TextView
                android:id="@+id/contact_links"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/contact_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineHeight="16dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/contact_end_slot"
        android:layout_width="@dimen/app_bar_button"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/contact_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />
        <ImageView
            android:id="@+id/contact_diverged"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:contentDescription="@string/contact_diverged"
            android:src="@drawable/ic_diverged"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
