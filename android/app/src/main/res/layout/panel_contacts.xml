<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorPrimary"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_bar_padding"
        android:paddingEnd="@dimen/app_bar_padding">

        <!-- Normal mode: back to the home addressbook listing. -->
        <ImageButton
            android:id="@+id/contacts_back"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Selection mode: cancel the selection. -->
        <ImageButton
            android:id="@+id/contacts_close"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel_selection"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- The addressbook name, or the selected-count while selecting. -->
        <TextView
            android:id="@+id/contacts_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/app_bar_title_padding"
            android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.ActionBar.Title"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Pushes the action icons to the right edge. -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Selection mode: link the selected rows into one contact. -->
        <ImageButton
            android:id="@+id/contacts_link"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/link_selected"
            android:src="@drawable/ic_link"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/contacts_delete"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_selected"
            android:src="@drawable/ic_delete_bar"
            android:tint="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <!-- Opens the addressbooks management screen. -->
        <ImageButton
            android:id="@+id/contacts_books"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/subscriptions_title"
            android:src="@drawable/ic_filter_list"
            android:tint="?android:attr/textColorPrimary" />

        <!-- The sync icon gives way to a spinner while a sync runs. -->
        <FrameLayout
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon">

            <ImageButton
                android:id="@+id/contacts_sync"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/contacts_sync"
                android:src="@drawable/ic_sync"
                android:tint="?android:attr/textColorPrimary" />

            <!-- The small style's own size: the M3 sync glyph carries
                 built-in margins, so a full 24dp spinner reads bigger
                 than the icon it replaces. -->
            <ProgressBar
                android:id="@+id/contacts_sync_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="?android:attr/textColorPrimary"
                android:visibility="gone" />

        </FrameLayout>

        <ImageButton
            android:id="@+id/contacts_search"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/contacts_search"
            android:src="@drawable/ic_search"
            android:tint="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/contacts_add"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/contacts_add"
            android:src="@drawable/ic_person_add"
            android:tint="?android:attr/textColorPrimary" />

    </LinearLayout>

    <!-- Full-width filter bar shown under the app bar on search; matches
         raw vCard content and clears on close. -->
    <LinearLayout
        android:id="@+id/contacts_search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/contacts_search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/contacts_search"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/contacts_search_close"
            android:layout_width="@dimen/app_bar_icon"
            android:layout_height="@dimen/app_bar_icon"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel_selection"
            android:src="@drawable/ic_close"
            android:tint="?android:attr/textColorSecondary" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Rows are full-bleed so their press/selection highlight spans
             the whole line; the letter gutter clearance and the app-bar
             title alignment come from the row's own start padding. -->
        <ListView
            android:id="@+id/contacts_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:scrollbars="none" />

        <!-- Centred placeholder shown when the list is empty: a search
             miss, or a genuinely empty addressbook (icon/subtitle set
             in renderContacts). -->
        <LinearLayout
            android:id="@+id/contacts_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/contacts_empty_icon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:contentDescription="@null"
                android:tint="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/contacts_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Sticky section letter: pinned to the top-left gutter,
             centred on the app-bar icon column (48dp box + 8dp bar
             padding puts the glyph centre at 32dp) and on a row's
             height, updated as the list scrolls. -->
        <TextView
            android:id="@+id/contacts_sticky_letter"
            android:layout_width="64dp"
            android:layout_height="66dp"
            android:gravity="center"
            android:textColor="?android:attr/colorAccent"
            android:textStyle="bold" />

    </FrameLayout>

</LinearLayout>
