<?xml version="1.0" encoding="utf-8"?>
<!-- The advanced raw-property editor's content: every line of the open
     contact's vCard as a tappable row (rows built in code), closed by
     the source block. Its bar elements live in the persistent chrome
     (activity_main.xml). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/advanced_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp" />

</ScrollView>
